{
  "name": "@ghostship/agent-profiler",
  "version": "0.3.0",
  "type": "module",
  "description": "Local trace viewer for Claude Code conversations — reads session transcripts and renders a waterfall UI.",
  "keywords": [
    "claude",
    "claude-code",
    "tracing",
    "observability",
    "agent",
    "llm",
    "anthropic"
  ],
  "homepage": "https://github.com/DevonPeroutky/agent-profiler#readme",
  "bugs": {
    "url": "https://github.com/DevonPeroutky/agent-profiler/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DevonPeroutky/agent-profiler.git"
  },
  "license": "Apache-2.0",
  "author": "Devon Peroutky",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "ui"
  ],
  "bin": {
    "agent-profiler": "./bin/agent-profiler.js"
  },
  "files": [
    "bin/",
    "lib/",
    "ui/dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "npm run dev -w ui",
    "build": "npm run build -w ui",
    "preview": "npm run preview -w ui",
    "start": "node bin/agent-profiler.js",
    "test": "node --test test/*.test.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && git config core.hooksPath .githooks || true",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
